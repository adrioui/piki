{
	"name": "@piki/scratchpad",
	"version": "0.80.2",
	"description": "Scratchpad path expansion and artifact management for piki",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": ["dist"],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"license": "MIT",
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"shx": "0.4.0",
		"typescript": "5.9.3",
		"vitest": "4.1.9"
	}
}
