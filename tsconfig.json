{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@piki/ai": ["./packages/ai/src/index.ts"],
			"@piki/ai/compat": ["./packages/ai/src/compat.ts"],
			"@piki/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@piki/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@piki/ai/dist/*": ["./packages/ai/src/*"],
			"@piki/agent-core": ["./packages/agent/src/index.ts"],

			"@piki/agent-core/*": ["./packages/agent/src/*"],
			"@piki/coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@piki/coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@piki/coding-agent/*": ["./packages/coding-agent/src/*"],
			"@piki/event-core": ["./packages/event-core/src/index.ts"],
			"@piki/event-core/types": ["./packages/event-core/src/types.ts"],
			"@piki/event-core/*": ["./packages/event-core/src/*"],
			"@piki/generate-id": ["./packages/generate-id/src/index.ts"],
			"@piki/generate-id/*": ["./packages/generate-id/src/*"],
			"@piki/harness": ["./packages/harness/src/index.ts"],
			"@piki/harness/*": ["./packages/harness/src/*"],
			"@piki/logger": ["./packages/logger/src/index.ts"],
			"@piki/logger/*": ["./packages/logger/src/*"],
			"@piki/orchestrator": ["./packages/orchestrator/src/index.ts"],
			"@piki/orchestrator/*": ["./packages/orchestrator/src/*"],
			"@piki/piki-client": ["./packages/piki-client/src/index.ts"],
			"@piki/piki-client/*": ["./packages/piki-client/src/*"],
			"@piki/ripgrep": ["./packages/ripgrep/src/index.ts"],
			"@piki/ripgrep/*": ["./packages/ripgrep/src/*"],
			"@piki/roles": ["./packages/roles/src/index.ts"],
			"@piki/roles/*": ["./packages/roles/src/*"],
			"@piki/scratchpad": ["./packages/scratchpad/src/index.ts"],
			"@piki/scratchpad/*": ["./packages/scratchpad/src/*"],
			"@piki/shell-classifier": ["./packages/shell-classifier/src/index.ts"],
			"@piki/shell-classifier/*": ["./packages/shell-classifier/src/*"],
			"@piki/skills": ["./packages/skills/src/index.ts"],
			"@piki/skills/*": ["./packages/skills/src/*"],
			"@piki/storage": ["./packages/storage/src/index.ts"],
			"@piki/storage/*": ["./packages/storage/src/*"],
			"@piki/tracing": ["./packages/tracing/src/index.ts"],
			"@piki/tracing/*": ["./packages/tracing/src/*"],
			"@piki/vcs": ["./packages/vcs/src/index.ts"],
			"@piki/vcs/*": ["./packages/vcs/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@piki/tui": ["./packages/tui/src/index.ts"],
			"@piki/tui/*": ["./packages/tui/src/*"],
			"@earendil-works/pi-agent-old": ["./packages/agent-old/src/index.ts"],
			"@earendil-works/pi-agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["**/dist/**", "packages/coding-agent/examples/extensions/gondolin/**"]
}
